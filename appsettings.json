{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Jwt": {
    "Key": "CHANGE_ME_FOR_LOCAL_DEV_ONLY",
    "Issuer": "LockHaven",
    "Audience": "LockHavenUsers",
    "TokenExpirationMinutes": 60,
    "RefreshTokenLength": 32
  },

  "BlobStorage": {
    "ConnectionString": "UseDevelopmentStorage=true",
    "ContainerName": "lockhaven-files"
  },

  "Storage": {
    "Provider": "Local"
  },

  "KeyEncryption": {
    "Provider": "VaultTransit"
  },

  "Vault": {
    "Address": "http://localhost:8200",
    "TransitKeyName": "lockhaven-file-encryption-key",
    "AuthMethod": "Token",
    "Token": ""
  },

  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=lockhaven;Username=postgres;Password=postgres;SSL Mode=Disable;Trust Server Certificate=true"
  },

  "FileValidation": {
    "EnableSignatureChecks": true
  },

  "Features": {
    "EnableSwagger": false
  }
}
